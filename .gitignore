# =====================================================
# PandaMarket - Root .gitignore
# =====================================================

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# Build outputs
dist/
build/
.next/
out/
.medusa/
.turbo/
.cache/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Testing
coverage/
.nyc_output/
playwright-report/
test-results/
playwright/.cache/

# IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Docker volumes (if using local bind mounts)
docker-data/

# Generated assets
public/uploads/
storage/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Temp
tmp/
temp/
*.tmp
